; Engine configuration file.
; Minimal project for Rift Tap M0–M1. Open this folder directly in Godot 4.6.

config_version=5

[application]

config/name="Rift Tap"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

; Load order matters: EventBus + Balance have no deps and must come first.
EventBus="*res://autoload/event_bus.gd"
Balance="*res://autoload/balance.gd"
NumberFormat="*res://autoload/number_format.gd"
GameState="*res://autoload/game_state.gd"
Economy="*res://autoload/economy.gd"
SurgeManager="*res://autoload/surge_manager.gd"
PrestigeManager="*res://autoload/prestige_manager.gd"
